{
  "name": "flowpro",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --open",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "nuke-and-run": "rm -rf node_modules pnpm-lock.yaml .nuxt .output && pnpm store prune && pnpm install && pnpm nuxt prepare && pnpm dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix"
  },
  "dependencies": {
    "@nuxt/eslint": "1.11.0",
    "@nuxt/hints": "1.0.0-alpha.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.2.1",
    "@vueuse/core": "^14.1.0",
    "eslint": "^9.39.1",
    "nuxt": "^4.2.1",
    "typescript": "^5.9.3",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/ui": "^3.2.4",
    "@vue/test-utils": "^2.4.10",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.1.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.20.0"
  }
}
